# test config that has no https. 

proxy_cache_path /var/cache/nginx/sports
levels=1:2
keys_zone=sports_cache:10m
max_size=500m
inactive=60m
use_temp_path=off;

server {
    listen 80;
    listen [::]:80;
    
    server_name cheesyman.com www.cheesyman.com;

    root /var/www/html;
    index index.html;

    # proxy to internal node server
    location /cfb_api/ {

        # Cache configuration
        proxy_cache sports_cache;
        proxy_cache_valid 200 5m;
        proxy_cache_key "$request_uri";
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503;
        proxy_cache_lock on;
        add_header X-Cache-Status $upstream_cache_status;

        #Other proxy settings
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location /cbb_api/ {

        # Cache configuration
        proxy_cache sports_cache;
        proxy_cache_valid 200 5m;
        proxy_cache_key "$request_uri";
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503;
        proxy_cache_lock on;
        add_header X-Cache-Status $upstream_cache_status;

        #Other proxy settings
        proxy_pass http://localhost:3500;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location /matchup_api/ {

        # Cache configuration
        proxy_cache sports_cache;
        proxy_cache_valid 200 5m;
        proxy_cache_key "$request_uri";
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503;
        proxy_cache_lock on;
        
        #Other proxy settings
        add_header X-Cache-Status $upstream_cache_status;
        proxy_pass http://localhost:3250;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }


    # Regular file handling for GET/POST/HEAD requests
    location / {
        
    	# Handle OPTIONS requests
        if ($request_method = OPTIONS) {
            add_header Allow "GET, POST, HEAD, OPTIONS";
            add_header Content-Length 0;
            add_header Content-Type text/plain;
            return 204;
        }
	try_files $uri $uri/ =404;
    }
}

